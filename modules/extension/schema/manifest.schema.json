{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://woki.local/schemas/wokiext-manifest.schema.json",
  "title": "Woki extension manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "apiVersion", "runtime", "permissions"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$",
      "description": "Reverse-DNS extension id. Must match installed package directory."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9A-Za-z][0-9A-Za-z.+-]*$"
    },
    "apiVersion": { "type": "integer", "const": 1 },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wasm"],
      "properties": {
        "wasm": {
          "type": "string",
          "default": "extension.wasm",
          "not": { "pattern": "^(?:/|.*\\.\\..*)$" }
        }
      }
    },
    "permissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["log", "paths", "storage", "config", "events"]
      }
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
              },
              "title": { "type": "string", "minLength": 1 },
              "category": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
